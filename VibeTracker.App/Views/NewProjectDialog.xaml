<Window x:Class="VibeTracker.App.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建项目" Width="520" SizeToContent="Height" MaxHeight="660"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.AppBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Style="{StaticResource GlassPanel}" Margin="22">
            <StackPanel>
                <TextBlock Text="新建项目" FontSize="21" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="项目、路径、Agent" FontSize="12"
                           Foreground="{StaticResource Brush.TextSubtle}" Margin="0,0,0,20"/>

                <TextBlock Text="项目名称" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtName" Height="36" FontSize="13"/>

                <TextBlock Text="项目路径" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,15,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtPath" Height="36" FontSize="13"/>
                    <Button Grid.Column="1" Content="选择" Width="72" Height="36" Margin="8,0,0,0"
                            Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            Click="BrowsePath_Click" Style="{StaticResource RoundedButton}"/>
                </Grid>

                <TextBlock Text="一句话需求" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,15,0,5"/>
                <TextBox x:Name="TxtSeed" Height="72" FontSize="13" TextWrapping="Wrap"
                         AcceptsReturn="True" Text="我要做..."/>

                <TextBlock Text="项目标签" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,15,0,5"/>
                <ComboBox x:Name="CmbTag" Height="36" FontSize="13"/>

                <TextBlock Text="启用 Agent" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,15,0,7"/>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkCodex" Content="Codex Desktop" Margin="0,0,16,0" FontSize="13" IsChecked="True"/>
                    <CheckBox x:Name="ChkClaude" Content="Claude Desktop" Margin="0,0,16,0" FontSize="13" IsChecked="True"/>
                    <CheckBox x:Name="ChkClaudeCode" Content="Claude Code" FontSize="13"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="取消" Width="84" Height="36" FontSize="13"
                            Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            Click="Cancel_Click" Style="{StaticResource RoundedButton}"/>
                    <Button Content="创建" Width="84" Height="36" FontSize="13" Margin="10,0,0,0"
                            Background="{StaticResource Brush.Primary}" Foreground="White"
                            BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1"
                            Click="Create_Click" Style="{StaticResource RoundedButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>

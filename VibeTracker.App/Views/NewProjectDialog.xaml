<Window x:Class="VibeTracker.App.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建项目" Width="520" SizeToContent="Height" MaxHeight="640"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.AppBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Style="{StaticResource Card}" Margin="20">
    <StackPanel>
        <TextBlock Text="新建项目" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="选择项目文件夹，并为桌面端 agent 写入追踪配置。"
                   FontSize="12" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,18"/>

        <!-- 项目名称 -->
        <TextBlock Text="项目名称" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtName" Height="34" FontSize="13" Padding="8,6" BorderBrush="#d0d0d0" BorderThickness="1"/>

        <!-- 项目路径 -->
        <TextBlock Text="项目路径" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,14,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtPath" Height="34" FontSize="13" Padding="8,6"
                     BorderBrush="#d0d0d0" BorderThickness="1" Background="White"/>
            <Button Grid.Column="1" Content="选择" Width="64" Height="34" Margin="8,0,0,0"
                    Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0" Click="BrowsePath_Click"
                    Style="{StaticResource RoundedButton}"/>
        </Grid>

        <!-- 种子需求 -->
        <TextBlock Text="一句话需求（种子）" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,14,0,4"/>
        <TextBox x:Name="TxtSeed" Height="68" FontSize="13" Padding="8,8" TextWrapping="Wrap"
                 AcceptsReturn="True" BorderBrush="#d0d0d0" BorderThickness="1"
                 Text="我要做..."/>

        <!-- 标签 -->
        <TextBlock Text="项目标签" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,14,0,4"/>
        <ComboBox x:Name="CmbTag" Height="34" FontSize="13"/>

        <!-- Agent 选择 -->
        <TextBlock Text="启用 Agent" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,14,0,4"/>
        <StackPanel Orientation="Horizontal">
            <CheckBox x:Name="ChkCodex" Content="Codex Desktop" Margin="0,0,16,0" FontSize="13" IsChecked="True"/>
            <CheckBox x:Name="ChkClaude" Content="Claude Desktop" Margin="0,0,16,0" FontSize="13" IsChecked="True"/>
            <CheckBox x:Name="ChkClaudeCode" Content="Claude Code" FontSize="13"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Width="80" Height="36" FontSize="13"
                    Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                    Click="Cancel_Click" Style="{StaticResource RoundedButton}"/>
            <Button Content="创建" Width="80" Height="36" FontSize="13" Margin="10,0,0,0"
                    Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                    Click="Create_Click" Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </StackPanel>
    </Border>
    </ScrollViewer>
</Window>

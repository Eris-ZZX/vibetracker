<Window x:Class="VibeTracker.App.Views.PathInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改路径" Height="160" Width="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#fafafa">
    <StackPanel Margin="20,16">
        <TextBlock Text="请输入项目的新路径：" FontSize="13" Foreground="#555" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtPath" Height="32" FontSize="13" Padding="8,6" BorderBrush="#d0d0d0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Width="70" Height="32" Click="Cancel_Click"
                    Background="Transparent" Foreground="#666" BorderBrush="#d0d0d0"
                    Style="{StaticResource RoundedButton}"/>
            <Button Content="确定" Width="70" Height="32" Margin="8,0,0,0" Click="Ok_Click"
                    Background="#4A90D9" Foreground="White" BorderThickness="0"
                    Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </StackPanel>
</Window>

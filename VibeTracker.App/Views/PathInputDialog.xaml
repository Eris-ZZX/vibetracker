<Window x:Class="VibeTracker.App.Views.PathInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改路径" Height="180" Width="480" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.AppBg}">
    <Border Style="{StaticResource Card}" Margin="16">
    <StackPanel>
        <TextBlock Text="修改项目路径" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="请输入项目的新路径：" FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtPath" Height="32" FontSize="13" Padding="8,6" BorderBrush="#d0d0d0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Width="70" Height="32" Click="Cancel_Click"
                    Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                    BorderBrush="{StaticResource Brush.Border}"
                    Style="{StaticResource RoundedButton}"/>
            <Button Content="确定" Width="70" Height="32" Margin="8,0,0,0" Click="Ok_Click"
                    Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                    Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </StackPanel>
    </Border>
</Window>

<Window x:Class="VibeTracker.App.Views.PathInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改路径" Height="190" Width="480" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.AppBg}">
    <Border Style="{StaticResource GlassPanel}" Margin="20">
        <StackPanel>
            <TextBlock Text="修改项目路径" FontSize="19" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="新的项目路径" FontSize="12" Foreground="{StaticResource Brush.TextSubtle}" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtPath" Height="36" FontSize="13"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="取消" Width="74" Height="34" Click="Cancel_Click"
                        Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        Style="{StaticResource RoundedButton}"/>
                <Button Content="确定" Width="74" Height="34" Margin="8,0,0,0" Click="Ok_Click"
                        Background="{StaticResource Brush.Primary}" Foreground="White"
                        BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1"
                        Style="{StaticResource RoundedButton}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

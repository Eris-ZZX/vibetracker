<Window x:Class="VibeTracker.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="440" Width="500" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#fafafa">
    <StackPanel Margin="24,20">
        <TextBlock Text="⚙️ 设置" FontSize="18" FontWeight="Bold" Foreground="#1a1a1a" Margin="0,0,0,20"/>

        <!-- 项目标签管理 -->
        <TextBlock Text="项目标签" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
        <TextBlock Text="管理新建项目时可选的标签。双击标签可编辑，点击 ✕ 删除。" FontSize="12" Foreground="#888" Margin="0,0,0,8"/>

        <Border Background="White" CornerRadius="6" Padding="8,8" BorderBrush="#e0e0e0" BorderThickness="1"
                MaxHeight="160">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="TagsPanel">
                    <!-- 标签由代码动态生成 -->
                </WrapPanel>
            </ScrollViewer>
        </Border>

        <!-- 添加标签 -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtNewTag" Height="32" FontSize="13" Padding="8,6"
                     BorderBrush="#d0d0d0" BorderThickness="1"
                     KeyDown="TxtNewTag_KeyDown"/>
            <Button Grid.Column="1" Content="➕ 添加" Width="70" Height="32" Margin="8,0,0,0"
                    Background="#4A90D9" Foreground="White" BorderThickness="0"
                    Click="AddTag_Click" Style="{StaticResource RoundedButton}"/>
        </Grid>

        <Separator Margin="0,16,0,16" Background="#e0e0e0" Height="1"/>

        <!-- 关于 -->
        <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
        <TextBlock Text="VibeTracker v1.0.0" FontSize="13" Foreground="#555" Margin="0,4,0,0"/>
        <TextBlock Text="让 agent 每个新 session 自动恢复上下文。" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>

        <Separator Margin="0,16,0,16" Background="#e0e0e0" Height="1"/>

        <Button Content="关闭" Width="80" Height="36" FontSize="13" HorizontalAlignment="Right"
                Background="#4A90D9" Foreground="White" BorderThickness="0"
                Click="Close_Click" Style="{StaticResource RoundedButton}"/>
    </StackPanel>
</Window>

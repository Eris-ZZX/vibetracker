<Window x:Class="VibeTracker.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="450" Width="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.AppBg}">
    <Border Style="{StaticResource GlassPanel}" Margin="22">
        <StackPanel>
            <TextBlock Text="设置" FontSize="21" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="标签、本地信息" FontSize="12"
                       Foreground="{StaticResource Brush.TextSubtle}" Margin="0,0,0,20"/>

            <TextBlock Text="项目标签" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="{StaticResource Brush.SurfaceRaised}" CornerRadius="16" Padding="12"
                    BorderBrush="{StaticResource Brush.BorderSoft}" BorderThickness="1"
                    MaxHeight="160">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="TagsPanel"/>
                </ScrollViewer>
            </Border>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtNewTag" Height="36" FontSize="13"
                         KeyDown="TxtNewTag_KeyDown"/>
                <Button Grid.Column="1" Content="添加" Width="76" Height="36" Margin="8,0,0,0"
                        Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        Click="AddTag_Click" Style="{StaticResource RoundedButton}"/>
            </Grid>

            <Separator Margin="0,18,0,18" Background="{StaticResource Brush.BorderSoft}" Height="1"/>

            <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold"/>
            <TextBlock Text="VibeTracker v1.0.0" FontSize="13" Foreground="{StaticResource Brush.Text}" Margin="0,6,0,0"/>
            <TextBlock Text="每个 session 自动恢复项目上下文。"
                       FontSize="12" Foreground="{StaticResource Brush.TextSubtle}" Margin="0,3,0,0"/>

            <Separator Margin="0,18,0,18" Background="{StaticResource Brush.BorderSoft}" Height="1"/>

            <Button Content="关闭" Width="82" Height="36" FontSize="13" HorizontalAlignment="Right"
                    Background="{StaticResource Brush.Primary}" Foreground="White"
                    BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1"
                    Click="Close_Click" Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </Border>
</Window>

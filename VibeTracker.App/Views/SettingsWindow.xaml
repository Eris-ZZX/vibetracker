<Window x:Class="VibeTracker.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="450" Width="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.AppBg}">
    <Border Style="{StaticResource Card}" Margin="20">
    <StackPanel>
        <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="维护项目标签和本地工具信息。"
                   FontSize="12" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,18"/>

        <!-- 项目标签管理 -->
        <TextBlock Text="项目标签" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Text="管理新建项目时可选的标签。双击标签可编辑，点击 ✕ 删除。"
                   FontSize="12" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,8"/>

        <Border Background="{StaticResource Brush.Surface}" CornerRadius="6" Padding="8,8"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                MaxHeight="160">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="TagsPanel">
                    <!-- 标签由代码动态生成 -->
                </WrapPanel>
            </ScrollViewer>
        </Border>

        <!-- 添加标签 -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtNewTag" Height="32" FontSize="13" Padding="8,6"
                     BorderBrush="#d0d0d0" BorderThickness="1"
                     KeyDown="TxtNewTag_KeyDown"/>
            <Button Grid.Column="1" Content="➕ 添加" Width="70" Height="32" Margin="8,0,0,0"
                    Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                    Click="AddTag_Click" Style="{StaticResource RoundedButton}"/>
        </Grid>

        <Separator Margin="0,16,0,16" Background="{StaticResource Brush.Border}" Height="1"/>

        <!-- 关于 -->
        <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold"/>
        <TextBlock Text="VibeTracker v1.0.0" FontSize="13" Foreground="{StaticResource Brush.Text}" Margin="0,4,0,0"/>
        <TextBlock Text="让 agent 每个新 session 自动恢复上下文。"
                   FontSize="12" Foreground="{StaticResource Brush.TextMuted}" Margin="0,2,0,0"/>

        <Separator Margin="0,16,0,16" Background="{StaticResource Brush.Border}" Height="1"/>

        <Button Content="关闭" Width="80" Height="36" FontSize="13" HorizontalAlignment="Right"
                Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                Click="Close_Click" Style="{StaticResource RoundedButton}"/>
    </StackPanel>
    </Border>
</Window>

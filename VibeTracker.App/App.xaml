<Application x:Class="VibeTracker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VibeTracker.App.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Color palette -->
        <SolidColorBrush x:Key="Brush.AppBg" Color="#EAF2F6"/>
        <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Brush.SurfaceRaised" Color="#FBFDFE"/>
        <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="#EEF5F8"/>
        <SolidColorBrush x:Key="Brush.Border" Color="#D4E1E8"/>
        <SolidColorBrush x:Key="Brush.BorderSoft" Color="#E7EFF3"/>
        <SolidColorBrush x:Key="Brush.Text" Color="#1E262E"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#677682"/>
        <SolidColorBrush x:Key="Brush.TextSubtle" Color="#97A6B0"/>
        <SolidColorBrush x:Key="Brush.Primary" Color="#8FA9B8"/>
        <SolidColorBrush x:Key="Brush.PrimaryHover" Color="#7795A5"/>
        <SolidColorBrush x:Key="Brush.PrimaryDark" Color="#5C7786"/>
        <SolidColorBrush x:Key="Brush.PrimarySoft" Color="#E3EEF3"/>
        <SolidColorBrush x:Key="Brush.PrimaryLine" Color="#C9DCE5"/>
        <SolidColorBrush x:Key="Brush.Warning" Color="#8A6654"/>
        <SolidColorBrush x:Key="Brush.WarningSoft" Color="#FBF7F1"/>
        <SolidColorBrush x:Key="Brush.WarningLine" Color="#E5D0B9"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceRaised}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="GlassPanel" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Background" Value="#DDFBFDFE"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <views:SelectedBgConverter x:Key="SelectedBgConverter"/>
        <views:SelectedFgConverter x:Key="SelectedFgConverter"/>
    </Application.Resources>
</Application>

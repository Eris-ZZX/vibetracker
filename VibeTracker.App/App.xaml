<Application x:Class="VibeTracker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VibeTracker.App.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- 色板 -->
        <SolidColorBrush x:Key="Brush.AppBg" Color="#F6F7F9"/>
        <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="#F1F4F8"/>
        <SolidColorBrush x:Key="Brush.Border" Color="#E2E7EE"/>
        <SolidColorBrush x:Key="Brush.Text" Color="#172033"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#667085"/>
        <SolidColorBrush x:Key="Brush.TextSubtle" Color="#98A2B3"/>
        <SolidColorBrush x:Key="Brush.Primary" Color="#2563EB"/>
        <SolidColorBrush x:Key="Brush.PrimarySoft" Color="#EAF1FF"/>
        <SolidColorBrush x:Key="Brush.Warning" Color="#D97706"/>
        <SolidColorBrush x:Key="Brush.WarningSoft" Color="#FFF7ED"/>

        <!-- 基础文本 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        </Style>

        <!-- 卡片 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <!-- 圆角按钮样式 -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        </Style>

        <!-- 选中背景色转换器 -->
        <views:SelectedBgConverter x:Key="SelectedBgConverter"/>
        <views:SelectedFgConverter x:Key="SelectedFgConverter"/>
    </Application.Resources>
</Application>

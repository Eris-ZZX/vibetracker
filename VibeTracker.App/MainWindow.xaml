<Window x:Class="VibeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VibeTracker" Height="720" Width="1120" MinHeight="620" MinWidth="960"
        Background="{StaticResource Brush.AppBg}" WindowStartupLocation="CenterScreen">
    <Grid Margin="26">
        <Border CornerRadius="26" Background="#CCFBFDFE"
                BorderBrush="#BFFFFFFF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#82F6FAFC"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0"
                        CornerRadius="26,0,0,26" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,26">
                            <Border Width="42" Height="42" CornerRadius="14"
                                    Background="{StaticResource Brush.Primary}">
                                <TextBlock Text="V" Foreground="White" FontSize="18" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="VibeTracker" FontSize="21" FontWeight="SemiBold"/>
                                <TextBlock Text="Project memory system" FontSize="12"
                                           Foreground="{StaticResource Brush.TextSubtle}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="1" Height="42" CornerRadius="14" Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="13,0"
                                Margin="0,0,0,24">
                            <TextBlock Text="搜索项目上下文" FontSize="13" Foreground="{StaticResource Brush.TextSubtle}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="WORKSPACES" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextSubtle}" Margin="8,0,0,10"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ProjectListItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="13" Margin="0,4" CornerRadius="16"
                                                    Background="{Binding IsSelected, Converter={StaticResource SelectedBgConverter}}"
                                                    BorderBrush="{StaticResource Brush.BorderSoft}" BorderThickness="1"
                                                    Cursor="Hand" MouseLeftButtonDown="ProjectCard_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8" Fill="{StaticResource Brush.Primary}"
                                                             Margin="0,4,12,0" VerticalAlignment="Top"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding IsSelected, Converter={StaticResource SelectedFgConverter}}"/>
                                                        <TextBlock Text="{Binding LastActivity}" FontSize="11"
                                                                   Foreground="{StaticResource Brush.TextSubtle}" Margin="0,5,0,0"/>
                                                        <Border Background="{StaticResource Brush.SurfaceMuted}"
                                                                CornerRadius="10" Padding="7,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                                                            <TextBlock Text="{Binding Tag}" FontSize="11" Foreground="{StaticResource Brush.TextMuted}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding StatusIcon}" FontSize="11"
                                                               Foreground="{StaticResource Brush.TextMuted}" Margin="8,1,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,20,0,0">
                            <Button Content="新建项目" Height="40" FontSize="13"
                                    Background="{StaticResource Brush.Primary}" Foreground="White"
                                    BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1"
                                    Click="NewProject_Click" Style="{StaticResource RoundedButton}"/>
                            <Button Content="设置" Height="38" FontSize="12" Margin="0,9,0,0"
                                    Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                    Click="Settings_Click" Style="{StaticResource RoundedButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="34,34,34,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="TxtProjectName" Text="请选择项目"
                                       FontSize="34" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="项目状态、记忆与 agent 交接" FontSize="14"
                                       Foreground="{StaticResource Brush.TextMuted}" Margin="3,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Content="刷新" Height="40" FontSize="13" Margin="0,0,10,0"
                                    Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                    Click="Refresh_Click" Style="{StaticResource RoundedButton}"/>
                            <Button Content="配置 Agent" Height="40" FontSize="13"
                                    Background="{StaticResource Brush.Primary}" Foreground="White"
                                    BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1"
                                    Click="ConfigAgent_Click" Style="{StaticResource RoundedButton}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="DashboardScroll">
                            <StackPanel x:Name="DashboardPanel">
                                <Border x:Name="DataErrorBanner" Background="{StaticResource Brush.WarningSoft}"
                                        CornerRadius="14" Padding="14,10" Margin="0,0,0,18"
                                        Visibility="Collapsed" BorderBrush="{StaticResource Brush.WarningLine}" BorderThickness="1">
                                    <TextBlock x:Name="TxtDataError" Text="" FontSize="12"
                                               Foreground="{StaticResource Brush.Warning}" TextWrapping="Wrap"/>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.32*"/>
                                        <ColumnDefinition Width="0.88*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GlassPanel}" Margin="0,0,11,11">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <TextBlock Text="CURRENT PROJECT PULSE" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Brush.TextSubtle}"/>
                                                <Border HorizontalAlignment="Right" Background="{StaticResource Brush.PrimarySoft}"
                                                        BorderBrush="{StaticResource Brush.PrimaryLine}" BorderThickness="1"
                                                        CornerRadius="12" Padding="10,4">
                                                    <TextBlock x:Name="TxtStatusIcon" Text="" FontSize="12"
                                                               Foreground="{StaticResource Brush.PrimaryDark}" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>

                                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                <TextBlock Text="让每个 agent 保持一致" FontSize="32" FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="TxtCurrentTask" Text="-" FontSize="14"
                                                           Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"
                                                           Margin="0,14,60,0"/>
                                            </StackPanel>

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border CornerRadius="16" Background="{StaticResource Brush.Surface}"
                                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                        Padding="15,10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock x:Name="TxtProgress" Text="0/0" FontSize="22" FontWeight="SemiBold"/>
                                                        <TextBlock Text="features" FontSize="11" Foreground="{StaticResource Brush.TextSubtle}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" CornerRadius="16" Background="{StaticResource Brush.Surface}"
                                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                        Padding="15,10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Agent" FontSize="22" FontWeight="SemiBold"/>
                                                        <TextBlock Text="handoff" FontSize="11" Foreground="{StaticResource Brush.TextSubtle}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ProgressBar Grid.Column="2" x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0"
                                                             VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="11,0,0,11">
                                        <StackPanel>
                                            <TextBlock Text="AGENT HANDOFF" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.TextSubtle}"/>
                                            <Border Margin="0,24,0,18" CornerRadius="18" Background="{StaticResource Brush.Surface}"
                                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="18">
                                                <StackPanel>
                                                    <Grid>
                                                        <TextBlock Text="Codex Desktop" FontSize="16" FontWeight="SemiBold"/>
                                                        <TextBlock Text="ready" HorizontalAlignment="Right" FontSize="12"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource Brush.PrimaryDark}"/>
                                                    </Grid>
                                                    <ProgressBar Height="9" Value="72" Minimum="0" Maximum="100" Margin="0,16,0,0"/>
                                                    <TextBlock x:Name="TxtAgentActivity" Text="暂无活动" FontSize="13"
                                                               Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"
                                                               Margin="0,14,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="96"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="上次更新" FontSize="12" Foreground="{StaticResource Brush.TextSubtle}"/>
                                                <TextBlock Grid.Column="1" x:Name="TxtLastUpdate" Text="-" FontSize="12"
                                                           Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GlassPanel}" Margin="0,11,11,0">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,14">
                                                <TextBlock Text="RECENT ACTIVITY" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Brush.TextSubtle}"/>
                                                <Border HorizontalAlignment="Right" Background="{StaticResource Brush.Surface}"
                                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                        CornerRadius="12" Padding="10,4">
                                                    <TextBlock Text="Today" FontSize="12" Foreground="{StaticResource Brush.TextMuted}"/>
                                                </Border>
                                            </Grid>
                                            <ItemsControl x:Name="RecentLogsList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="14" Background="{StaticResource Brush.Surface}"
                                                                BorderBrush="{StaticResource Brush.BorderSoft}" BorderThickness="1"
                                                                Padding="13" Margin="0,5">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28"/>
                                                                    <ColumnDefinition Width="58"/>
                                                                    <ColumnDefinition Width="72"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="12"
                                                                           Foreground="{StaticResource Brush.TextSubtle}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding DisplayTime}" FontSize="11"
                                                                           Foreground="{StaticResource Brush.TextSubtle}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="12"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource Brush.PrimaryDark}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding Action}" FontSize="12"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="TxtNoLogs" Text="暂无活动记录" FontSize="12"
                                                       Foreground="{StaticResource Brush.TextSubtle}"
                                                       Visibility="Collapsed" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="11,11,0,0">
                                        <StackPanel>
                                            <TextBlock Text="BUG TRACKER" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.TextSubtle}" Margin="0,0,0,12"/>
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl x:Name="BugsList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="10" Background="{StaticResource Brush.Surface}"
                                                                    BorderBrush="{StaticResource Brush.BorderSoft}" BorderThickness="1"
                                                                    Padding="10" Margin="0,3">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Action}" FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource Brush.Text}" TextWrapping="Wrap"/>
                                                                        <Border CornerRadius="6" Padding="6,2" Margin="8,0,0,0"
                                                                                Background="{Binding StatusColor}">
                                                                            <TextBlock Text="{Binding StatusTag}" FontSize="10" Foreground="White"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource Brush.TextSubtle}"
                                                                                   Text="{Binding DisplayTime}" Width="72"/>
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource Brush.PrimaryDark}"
                                                                                   Text="{Binding Source}" Width="52"/>
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource Brush.TextMuted}"
                                                                                   Text="{Binding Cause}" TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                            <TextBlock x:Name="TxtNoBugs" Text="没有记录 bug" FontSize="12"
                                                       Foreground="{StaticResource Brush.TextSubtle}"
                                                       Visibility="Collapsed" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Row 2: Feature Checklist -->
                                    <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource GlassPanel}"
                                            Margin="0,11,0,0">
                                        <StackPanel>
                                            <TextBlock Text="FEATURE CHECKLIST" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.TextSubtle}" Margin="0,0,0,14"/>
                                            <ItemsControl x:Name="FeatureChecklist">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,3">
                                                            <!-- Feature header -->
                                                            <Border CornerRadius="12" Background="{StaticResource Brush.Surface}"
                                                                    BorderBrush="{StaticResource Brush.BorderSoft}" BorderThickness="1"
                                                                    Padding="12,8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="32"/>
                                                                        <ColumnDefinition Width="64"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="14"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Id}" FontSize="12"
                                                                               FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSubtle}"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Title}" FontSize="13"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="3" Text="{Binding Steps.Count, StringFormat={}+{0} steps}"
                                                                               FontSize="11" Foreground="{StaticResource Brush.TextSubtle}"
                                                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                                                               Visibility="{Binding HasSteps, Converter={StaticResource BoolToVisibility}}"/>
                                                                </Grid>
                                                            </Border>
                                                            <!-- Nested steps -->
                                                            <ItemsControl ItemsSource="{Binding Steps}" Margin="28,2,0,0"
                                                                          Visibility="{Binding HasSteps, Converter={StaticResource BoolToVisibility}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="8" Background="{StaticResource Brush.SurfaceMuted}"
                                                                                Padding="8,4" Margin="0,1">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding StatusIcon}" FontSize="11" Width="22"/>
                                                                                <TextBlock Text="{Binding Id}" FontSize="11" FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource Brush.TextSubtle}" Width="44"/>
                                                                                <TextBlock Text="{Binding Title}" FontSize="11"
                                                                                           Foreground="{StaticResource Brush.TextMuted}"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="TxtNoFeatures" Text="暂无功能清单" FontSize="12"
                                                       Foreground="{StaticResource Brush.TextSubtle}"
                                                       Visibility="Collapsed" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Border x:Name="EmptyPanel" Style="{StaticResource GlassPanel}" Width="380" Padding="28"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="选择一个项目" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="打开左侧项目，或创建新项目。"
                                           FontSize="13" Foreground="{StaticResource Brush.TextMuted}"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                                <Button Content="新建项目" Height="38" Width="126" Margin="0,20,0,0"
                                        Background="{StaticResource Brush.Primary}" Foreground="White"
                                        BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1"
                                        Click="NewProject_Click" Style="{StaticResource RoundedButton}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

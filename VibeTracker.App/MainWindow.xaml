<Window x:Class="VibeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VibeTracker" Height="680" Width="1040" MinHeight="560" MinWidth="860"
        Background="{StaticResource Brush.AppBg}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧项目导航 -->
        <Border Grid.Column="0" Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="18,18,18,12">
                    <TextBlock Text="VibeTracker" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="项目过程面板" FontSize="12" Foreground="{StaticResource Brush.TextMuted}" Margin="0,3,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProjectListItems" Margin="10,0,10,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" Margin="0,3" CornerRadius="8"
                                        Background="{Binding IsSelected, Converter={StaticResource SelectedBgConverter}}"
                                        Cursor="Hand" MouseLeftButtonDown="ProjectCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding IsSelected, Converter={StaticResource SelectedFgConverter}}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StatusIcon}" FontSize="12" Margin="8,0,0,0"/>
                                        </Grid>

                                        <Border Grid.Row="1" Background="{StaticResource Brush.SurfaceMuted}"
                                                CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,7,0,0">
                                            <TextBlock Text="{Binding Tag}" FontSize="11" Foreground="{StaticResource Brush.TextMuted}"/>
                                        </Border>

                                        <TextBlock Grid.Row="2" Text="{Binding LastActivity}" FontSize="11"
                                                   Foreground="{StaticResource Brush.TextSubtle}" Margin="0,7,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="14">
                    <StackPanel>
                        <Button Content="＋ 新建项目" Height="38" FontSize="13"
                                Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                                Click="NewProject_Click" Style="{StaticResource RoundedButton}"/>
                        <Button Content="设置" Height="34" FontSize="12" Margin="0,8,0,0"
                                Background="{StaticResource Brush.SurfaceMuted}" Foreground="{StaticResource Brush.TextMuted}"
                                BorderThickness="0" Click="Settings_Click" Style="{StaticResource RoundedButton}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 右侧仪表盘 -->
        <Border Grid.Column="1" Background="{StaticResource Brush.AppBg}">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="DashboardScroll">
                    <StackPanel Margin="28,24,28,28" x:Name="DashboardPanel">
                        <!-- 顶部 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtProjectName" Text="请选择一个项目"
                                               FontSize="24" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    <Border Background="{StaticResource Brush.PrimarySoft}" CornerRadius="6"
                                            Padding="8,3" Margin="12,1,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtStatusIcon" Text="" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="查看当前状态、最近活动和需要 agent 记住的问题"
                                           FontSize="12" Foreground="{StaticResource Brush.TextMuted}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Content="刷新 F5" Height="32" FontSize="12" Margin="0,0,8,0"
                                        Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextMuted}"
                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                        Click="Refresh_Click" Style="{StaticResource RoundedButton}"/>
                                <Button Content="配置 Agent F2" Height="32" FontSize="12"
                                        Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                                        Click="ConfigAgent_Click" Style="{StaticResource RoundedButton}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 指标区 -->
                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="功能进度" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextMuted}"/>
                                        <TextBlock x:Name="TxtProgress" Text="0/0" FontSize="26" FontWeight="Bold"
                                                   HorizontalAlignment="Right" Foreground="{StaticResource Brush.Primary}"/>
                                    </Grid>
                                    <ProgressBar x:Name="ProgressBar" Height="10" Minimum="0" Maximum="100" Value="0"
                                                 Margin="0,16,0,0" Background="{StaticResource Brush.SurfaceMuted}"
                                                 Foreground="{StaticResource Brush.Primary}" BorderThickness="0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Agent 活动" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextMuted}"/>
                                    <TextBlock x:Name="TxtAgentActivity" Text="暂无活动"
                                               FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 当前状态 -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="当前状态" FontSize="15" FontWeight="SemiBold"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="当前在做" FontSize="12"
                                               Foreground="{StaticResource Brush.TextMuted}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtCurrentTask" Text="-"
                                               FontSize="13" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="上次更新" FontSize="12"
                                               Foreground="{StaticResource Brush.TextMuted}" Margin="0,10,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtLastUpdate" Text="-"
                                               FontSize="13" Foreground="{StaticResource Brush.TextMuted}" Margin="0,10,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 最近活动 -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="最近活动" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="RecentLogsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="72"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayTime}" FontSize="11"
                                                           Foreground="{StaticResource Brush.TextSubtle}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Action}" FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtNoLogs" Text="暂无活动记录" FontSize="12"
                                           Foreground="{StaticResource Brush.TextSubtle}"
                                           Visibility="Collapsed" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 未解决问题 -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                                Background="{StaticResource Brush.WarningSoft}" BorderBrush="#FED7AA">
                            <StackPanel>
                                <TextBlock Text="未解决的问题" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.Warning}" Margin="0,0,0,10"/>
                                <ItemsControl x:Name="ProblemsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Tag}" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="{StaticResource Brush.Warning}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="12"
                                                           Foreground="{StaticResource Brush.Text}" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="TxtNoProblems" Text="没有未解决的问题" FontSize="12"
                                           Foreground="{StaticResource Brush.TextSubtle}"
                                           Visibility="Collapsed" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 空状态 -->
                <Border x:Name="EmptyPanel" Style="{StaticResource Card}" Width="360" Padding="24"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="选择一个项目" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="从左侧项目列表打开仪表盘，或新建一个项目开始追踪。"
                                   FontSize="12" Foreground="{StaticResource Brush.TextMuted}"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="新建项目" Height="36" Width="120" Margin="0,18,0,0"
                                Background="{StaticResource Brush.Primary}" Foreground="White" BorderThickness="0"
                                Click="NewProject_Click" Style="{StaticResource RoundedButton}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

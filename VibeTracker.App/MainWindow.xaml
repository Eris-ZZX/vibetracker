<Window x:Class="VibeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VibeTracker" Height="620" Width="900" MinHeight="480" MinWidth="720"
        Background="#f5f5f5" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ 左侧：项目列表 ═══════ -->
        <Border Grid.Column="0" Background="White" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <Border Grid.Row="0" Padding="16,14" Background="#fff">
                    <TextBlock Text="📁 项目列表" FontSize="16" FontWeight="SemiBold" Foreground="#1a1a1a"/>
                </Border>

                <!-- 项目列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProjectListItems" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,2" CornerRadius="6"
                                        Background="{Binding IsSelected, Converter={StaticResource SelectedBgConverter}}"
                                        Cursor="Hand" MouseLeftButtonDown="ProjectCard_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                       Foreground="{Binding IsSelected, Converter={StaticResource SelectedFgConverter}}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding StatusIcon}" FontSize="11" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Tag}" FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding LastActivity}" FontSize="10" Foreground="#aaa" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 底部按钮 -->
                <StackPanel Grid.Row="2" Margin="12,8">
                    <Button Content="＋ 新建项目" Height="36" FontSize="13"
                            Background="#4A90D9" Foreground="White" BorderThickness="0"
                            Click="NewProject_Click" Style="{StaticResource RoundedButton}"/>
                    <Button Content="⚙️ 设置" Height="32" FontSize="12" Margin="0,4,0,0"
                            Background="Transparent" Foreground="#666" BorderThickness="0"
                            Click="Settings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ 右侧：仪表盘 ═══════ -->
        <Border Grid.Column="1" Background="#fafafa">
            <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="DashboardScroll">
                <StackPanel Margin="28,24" x:Name="DashboardPanel">
                    <!-- 标题 -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtProjectName" Text="请选择一个项目" FontSize="20" FontWeight="Bold" Foreground="#1a1a1a"/>
                            <TextBlock x:Name="TxtStatusIcon" Text="" FontSize="14" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="🔄 刷新 F5" Height="28" FontSize="11" Margin="0,0,8,0"
                                    Background="#f0f0f0" Foreground="#555" BorderThickness="0"
                                    Click="Refresh_Click" Style="{StaticResource RoundedButton}"/>
                            <Button Content="🔌 配置 Agent F2" Height="28" FontSize="11"
                                    Background="#f0f0f0" Foreground="#555" BorderThickness="0"
                                    Click="ConfigAgent_Click" Style="{StaticResource RoundedButton}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 进度卡片 -->
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,16,0,0"
                            BorderBrush="#e8e8e8" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="功能进度" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                            <ProgressBar x:Name="ProgressBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                         Background="#e8e8e8" Foreground="#4A90D9" BorderThickness="0"/>
                            <TextBlock x:Name="TxtProgress" Text="0/0" FontSize="18" FontWeight="Bold"
                                       Foreground="#4A90D9" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 详情卡片 -->
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,12,0,0"
                            BorderBrush="#e8e8e8" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="当前在做" FontSize="13" Foreground="#666" Width="80"/>
                                <TextBlock x:Name="TxtCurrentTask" Text="-" FontSize="13" Foreground="#1a1a1a"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="上次更新" FontSize="13" Foreground="#666" Width="80"/>
                                <TextBlock x:Name="TxtLastUpdate" Text="-" FontSize="13" Foreground="#1a1a1a"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Agent 活动" FontSize="13" Foreground="#666" Width="80"/>
                                <TextBlock x:Name="TxtAgentActivity" Text="⚫ 暂无活动" FontSize="13" Foreground="#1a1a1a"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 最近活动 -->
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,12,0,0"
                            BorderBrush="#e8e8e8" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📜 最近活动" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="RecentLogsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding TypeIcon}" FontSize="12" Width="22"/>
                                            <TextBlock FontSize="12" Foreground="#888" Text="{Binding Time, StringFormat={}{0:HH:mm}}" Width="44"/>
                                            <TextBlock FontSize="12" Foreground="#4A90D9" Width="56" Text="{Binding Source}"/>
                                            <TextBlock FontSize="12" Foreground="#1a1a1a" Text="{Binding Action}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoLogs" Text="暂无活动记录" FontSize="12" Foreground="#aaa"
                                       Visibility="Collapsed" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 未解决的坑 -->
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,12,0,24"
                            BorderBrush="#e8e8e8" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚠️ 未解决的坑" FontSize="14" FontWeight="SemiBold" Foreground="#e67e22" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="ProblemsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Tag}" FontSize="12" Foreground="#e67e22" Width="80"/>
                                            <TextBlock Text="{Binding Title}" FontSize="12" Foreground="#1a1a1a"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoProblems" Text="没有未解决的问题 🎉" FontSize="12" Foreground="#aaa"
                                       Visibility="Collapsed" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 空状态 -->
                    <StackPanel x:Name="EmptyPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="👈 选择一个项目或新建一个" FontSize="16" Foreground="#aaa" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
